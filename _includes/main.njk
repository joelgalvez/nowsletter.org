<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>
            {% if title %}
                {{ title }} — nowsletter.org{% else %}nowsletter.org{% endif %}
        </title>
        <link rel="icon" href="/favicon.ico">
        <link rel="stylesheet" href="/style.css">
    </head>
    <body class="bg-gray-100">
        {% if page.url != "/" %}
            <a href="/" class="inline-block text-2xl italic font-medium uppercase p-4">Nowsletter</a>
        {% endif %}
        <div class="text text-width mx-auto px-2 md:px-4 py-8 md:py-16 text-lg md:text-xl font-medium ">
            {{ content | safe }}
        </div>
    </body>
</html>