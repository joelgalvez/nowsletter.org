{
  "name": "nowsletter.org",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./style.css --minify",
    "watch:css": "tailwindcss -i ./src/input.css -o ./style.css --watch",
    "copy:content": "rsync -a --delete /Users/joel/Nextcloud/Apps/Obsidian/joel/nowsletter.org/Website/ Website/ && cp -r static/ Website/",
    "build": "npm run copy:content && npm run build:css && eleventy",
    "build:ci": "npm run build:css && eleventy",
    "watch:content": "chokidar \"/Users/joel/Nextcloud/Apps/Obsidian/joel/nowsletter.org/Website/**/*\" -c \"npm run copy:content\" -d 500",
    "serve": "eleventy --serve",
    "dev": "npm run copy:content && npm-run-all --parallel watch:css watch:content serve"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5"
  },
  "devDependencies": {
    "@photogabble/eleventy-plugin-interlinker": "^1.1.2",
    "@tailwindcss/cli": "^4.2.2",
    "chokidar-cli": "^3.0.0",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4.2.2"
  }
}
